    {
      "text": "%python\r\nimport folium\r\nfrom branca.colormap import LinearColormap\r\nimport json\r\nimport pandas as pd\r\n\r\nviajes = pd.read_csv('/data/viajes_por_destino.csv')\r\ntarifas = pd.read_csv('/data/tarifa_por_destino.csv').set_index('location_id')\r\npropinas = pd.read_csv('/data/propina_por_destino.csv').set_index('location_id')\r\ndistancias = pd.read_csv('/data/distancia_por_destino.csv').set_index('location_id')\r\nduraciones = pd.read_csv('/data/duracion_por_destino.csv').set_index('location_id')\r\ningresos = pd.read_csv('/data/ingresos_por_destino.csv').set_index('location_id')\r\n\r\nviajes['location_id'] = viajes['location_id'].astype(int)\r\nviajes_idx = viajes.set_index('location_id')\r\n\r\nwith open('/data/nyc_taxi_zones.geojson') as f:\r\n    geojson = json.load(f)\r\n\r\ncolormap = LinearColormap(\r\n    colors=['#e8f4f8', '#313695', '#74add1', '#ffffbf', '#f46d43', '#a50026'],\r\n    vmin=viajes['viajes'].min(),\r\n    vmax=viajes['viajes'].max(),\r\n    caption='Viajes por zona de destino'\r\n)\r\ndef fmt_num(val):\r\n    try: return f\"{int(val):,}\"\r\n    except: return 'N/A'\r\n\r\ndef fmt_dec(val):\r\n    try: return f\"{float(val):.2f}\"\r\n    except: return 'N/A'\r\n\r\nm = folium.Map(location=[40.7128, -74.0060], zoom_start=11)\r\n\r\nfolium.GeoJson(\r\n    geojson,\r\n    style_function=lambda feature: {\r\n        'fillColor': colormap(viajes_idx['viajes'].get(feature['properties']['LocationID'], 0)),\r\n        'color': 'black',\r\n        'weight': 0.5,\r\n        'fillOpacity': 0.7\r\n    },\r\n    tooltip=folium.GeoJsonTooltip(\r\n        fields=['zone', 'borough'],\r\n        aliases=['Zona', 'Distrito'],\r\n        localize=True\r\n    )\r\n).add_to(m)\r\n\r\n# Tooltip detallado por zona\r\nfor feature in geojson[\"features\"]:\r\n    loc_id = feature[\"properties\"][\"LocationID\"]\r\n    zona = feature[\"properties\"][\"zone\"]\r\n    borough = feature[\"properties\"][\"borough\"]\r\n\r\n    v = viajes_idx.loc[loc_id, 'viajes'] if loc_id in viajes_idx.index else 'N/A'\r\n    t = tarifas.loc[loc_id, 'tarifa_media'] if loc_id in tarifas.index else 'N/A'\r\n    p = propinas.loc[loc_id, 'propina_media'] if loc_id in propinas.index else 'N/A'\r\n    d = distancias.loc[loc_id, 'distancia_media'] if loc_id in distancias.index else 'N/A'\r\n    dur = duraciones.loc[loc_id, 'duracion_media'] if loc_id in duraciones.index else 'N/A'\r\n    i = ingresos.loc[loc_id, 'ingresos_totales'] if loc_id in ingresos.index else 'N/A'\r\n\r\n    folium.GeoJson(\r\n        feature,\r\n        style_function=lambda x: {\"fillOpacity\": 0, \"weight\": 0},\r\n        tooltip=folium.Tooltip(f\"\"\"\r\n            <b>{zona}</b> — {borough}<br>\r\n            🏁 Destinos: {fmt_num(v)}<br>\r\n            💰 Tarifa media: ${fmt_dec(t)}<br>\r\n            💵 Propina media: ${fmt_dec(p)}<br>\r\n            📍 Distancia media: {fmt_dec(d)} millas<br>\r\n            ⏱ Duración media: {fmt_dec(dur)} min<br>\r\n            💼 Ingresos totales: ${fmt_num(i)}\r\n        \"\"\")\r\n    ).add_to(m)\r\n\r\ncolormap.add_to(m)\r\nprint(\"%html \" + m._repr_html_())",
