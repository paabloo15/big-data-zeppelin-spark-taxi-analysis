    {
      "text": "%spark\r\nimport java.io.PrintWriter\r\n\r\nval viajesD = spark.sql(\"SELECT DOLocationID as location_id, COUNT(*) as viajes FROM dfFinal GROUP BY DOLocationID\").collect()\r\nval w1 = new PrintWriter(\"/data/viajes_por_destino.csv\")\r\nw1.println(\"location_id,viajes\")\r\nviajesD.foreach(r => w1.println(s\"${r(0)},${r(1)}\"))\r\nw1.close()\r\n\r\nval tarifaD = spark.sql(\"SELECT DOLocationID as location_id, ROUND(AVG(fare_amount),2) as tarifa_media FROM dfFinal GROUP BY DOLocationID\").collect()\r\nval w2 = new PrintWriter(\"/data/tarifa_por_destino.csv\")\r\nw2.println(\"location_id,tarifa_media\")\r\ntarifaD.foreach(r => w2.println(s\"${r(0)},${r(1)}\"))\r\nw2.close()\r\n\r\nval propinaD = spark.sql(\"SELECT DOLocationID as location_id, ROUND(AVG(tip_amount),2) as propina_media FROM dfFinal WHERE tipo_pago = 'Tarjeta' GROUP BY DOLocationID\").collect()\r\nval w3 = new PrintWriter(\"/data/propina_por_destino.csv\")\r\nw3.println(\"location_id,propina_media\")\r\npropinaD.foreach(r => w3.println(s\"${r(0)},${r(1)}\"))\r\nw3.close()\r\n\r\nval distanciaD = spark.sql(\"SELECT DOLocationID as location_id, ROUND(AVG(trip_distance),2) as distancia_media FROM dfFinal GROUP BY DOLocationID\").collect()\r\nval w4 = new PrintWriter(\"/data/distancia_por_destino.csv\")\r\nw4.println(\"location_id,distancia_media\")\r\ndistanciaD.foreach(r => w4.println(s\"${r(0)},${r(1)}\"))\r\nw4.close()\r\n\r\nval duracionD = spark.sql(\"SELECT DOLocationID as location_id, ROUND(AVG(duracion_minutos),2) as duracion_media FROM dfFinal GROUP BY DOLocationID\").collect()\r\nval w5 = new PrintWriter(\"/data/duracion_por_destino.csv\")\r\nw5.println(\"location_id,duracion_media\")\r\nduracionD.foreach(r => w5.println(s\"${r(0)},${r(1)}\"))\r\nw5.close()\r\n\r\nval ingresosD = spark.sql(\"SELECT DOLocationID as location_id, ROUND(SUM(total_amount),2) as ingresos_totales FROM dfFinal GROUP BY DOLocationID\").collect()\r\nval w6 = new PrintWriter(\"/data/ingresos_por_destino.csv\")\r\nw6.println(\"location_id,ingresos_totales\")\r\ningresosD.foreach(r => w6.println(s\"${r(0)},${r(1)}\"))\r\nw6.close()\r\n\r\nprintln(\"CSVs de destino exportados\")",
