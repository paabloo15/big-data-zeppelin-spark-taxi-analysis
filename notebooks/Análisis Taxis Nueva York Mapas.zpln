      "text": "%spark\r\nimport org.apache.spark.sql.functions._\r\n\r\nval df = spark.read\r\n  .parquet(\"/data/yellow_tripdata_2025-01.parquet\")\r\n\r\ndf.printSchema()\r\nprintln(s\"Total registros: ${df.count()}\")\r\ndf.show(5)",
