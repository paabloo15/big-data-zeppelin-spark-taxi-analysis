    {
      "text": "%spark\r\nimport org.apache.spark.sql.functions._\r\n\r\n// Cargar zonas desde GeoJSON\r\nval zonasRaw = spark.read\r\n  .option(\"multiline\", \"true\")\r\n  .json(\"/data/nyc_taxi_zones.geojson\")\r\n\r\n// Explotar el array de features\r\nval zonas = zonasRaw\r\n  .select(explode(col(\"features\")).alias(\"feature\"))\r\n  .select(\r\n    col(\"feature.properties.LocationID\").cast(\"integer\").alias(\"LocationID\"),\r\n    col(\"feature.properties.zone\").alias(\"Zone\"),\r\n    col(\"feature.properties.borough\").alias(\"Borough\"),\r\n    col(\"feature.properties.service_zone\").alias(\"service_zone\")\r\n  )\r\n\r\n// Zonas de recogida\r\nval zonasRecogida = zonas\r\n  .withColumnRenamed(\"LocationID\", \"pu_id\")\r\n  .withColumnRenamed(\"Zone\", \"zona_recogida\")\r\n  .withColumnRenamed(\"Borough\", \"borough_recogida\")\r\n  .withColumnRenamed(\"service_zone\", \"service_zone_recogida\")\r\n\r\n// Zonas de destino\r\nval zonasDestino = zonas\r\n  .withColumnRenamed(\"LocationID\", \"do_id\")\r\n  .withColumnRenamed(\"Zone\", \"zona_destino\")\r\n  .withColumnRenamed(\"Borough\", \"borough_destino\")\r\n  .withColumnRenamed(\"service_zone\", \"service_zone_destino\")\r\n\r\n// Join por ID numérico\r\nval dfConZonas = dfClean\r\n  .join(zonasRecogida, df(\"PULocationID\") === col(\"pu_id\"), \"left\")\r\n  .drop(\"pu_id\")\r\n  .join(zonasDestino, df(\"DOLocationID\") === col(\"do_id\"), \"left\")\r\n  .drop(\"do_id\")\r\n\r\n// Traducir códigos a texto y añadir duración\r\nval dfFinal = dfConZonas\r\n  .withColumn(\"vendor\",\r\n    when(col(\"VendorID\") === 1, \"Creative Mobile Technologies\")\r\n    .when(col(\"VendorID\") === 2, \"VeriFone Inc\")\r\n    .otherwise(\"Desconocido\")\r\n  )\r\n  .withColumn(\"tipo_pago\",\r\n    when(col(\"payment_type\") === 1, \"Tarjeta\")\r\n    .when(col(\"payment_type\") === 2, \"Efectivo\")\r\n    .when(col(\"payment_type\") === 3, \"Sin cargo\")\r\n    .when(col(\"payment_type\") === 4, \"Disputa\")\r\n    .when(col(\"payment_type\") === 5, \"Desconocido\")\r\n    .when(col(\"payment_type\") === 6, \"Viaje anulado\")\r\n    .otherwise(\"Otro\")\r\n  )\r\n  .withColumn(\"tarifa_tipo\",\r\n    when(col(\"RatecodeID\") === 1, \"Estándar\")\r\n    .when(col(\"RatecodeID\") === 2, \"JFK\")\r\n    .when(col(\"RatecodeID\") === 3, \"Newark\")\r\n    .when(col(\"RatecodeID\") === 4, \"Nassau/Westchester\")\r\n    .when(col(\"RatecodeID\") === 5, \"Tarifa negociada\")\r\n    .when(col(\"RatecodeID\") === 6, \"Viaje en grupo\")\r\n    .otherwise(\"Desconocido\")\r\n  )\r\n  .withColumn(\"store_and_fwd\",\r\n    when(col(\"store_and_fwd_flag\") === \"Y\", \"Sí\")\r\n    .when(col(\"store_and_fwd_flag\") === \"N\", \"No\")\r\n    .otherwise(\"Desconocido\")\r\n  )\r\n  .withColumn(\"duracion_minutos\",\r\n    round((unix_timestamp(col(\"tpep_dropoff_datetime\")) -\r\n           unix_timestamp(col(\"tpep_pickup_datetime\"))) / 60, 2)\r\n  )\r\n  .drop(\"VendorID\", \"payment_type\", \"RatecodeID\", \"store_and_fwd_flag\")\r\n\r\ndfFinal.cache()\r\nprintln(s\"Total registros: ${dfFinal.count()}\")\r\ndfFinal.createOrReplaceTempView(\"dfFinal\")\r\ndfFinal.printSchema()",
      "user": "anonymous",
      "dateUpdated": "2026-04-26T16:40:35+0000",
