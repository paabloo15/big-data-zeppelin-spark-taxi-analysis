      "text": "%spark\r\n\r\nval dfClean = df\r\n  // Eliminar filas con nulos en columnas críticas\r\n  .filter(col(\"tpep_pickup_datetime\").isNotNull)\r\n  .filter(col(\"tpep_dropoff_datetime\").isNotNull)\r\n  .filter(col(\"trip_distance\").isNotNull)\r\n  .filter(col(\"fare_amount\").isNotNull)\r\n  .filter(col(\"total_amount\").isNotNull)\r\n  .filter(col(\"PULocationID\").isNotNull)\r\n  .filter(col(\"DOLocationID\").isNotNull)\r\n  .filter(col(\"PULocationID\").between(1, 263))\r\n  .filter(col(\"DOLocationID\").between(1, 263))\r\n\r\n  // Distancia debe ser positiva\r\n  .filter(col(\"trip_distance\") > 0)\r\n\r\n  // Debe haber mínimo un pasajero\r\n  .filter(col(\"passenger_count\") >= 1)\r\n    \r\n  // Tarifa debe ser positiva\r\n  .filter(col(\"fare_amount\") > 0)\r\n  .filter(col(\"total_amount\") > 0)\r\n\r\n  // Fechas dentro del rango esperado del dataset\r\n  .filter(year(col(\"tpep_pickup_datetime\")) === 2025)\r\n\r\n  // Dropoff debe ser posterior al pickup\r\n  .filter(col(\"tpep_dropoff_datetime\") > col(\"tpep_pickup_datetime\"))\r\n\r\ndfClean.cache()\r\n\r\nval totalRegistros = df.count()\r\nval descartados = totalRegistros - dfClean.count()\r\nprintln(f\"Registros originales:  $totalRegistros%7d\")\r\nprintln(f\"Registros limpios:     ${dfClean.count()}%7d\")\r\nprintln(f\"Registros descartados: $descartados%7d (${descartados * 100.0 / totalRegistros}%.2f%%)\")",
      "user": "anonymous",
      "dateUpdated": "2026-04-26T16:40:34+0000",
