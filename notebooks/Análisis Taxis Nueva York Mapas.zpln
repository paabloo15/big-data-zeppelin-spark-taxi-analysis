    {
      "text": "%spark\r\nimport java.io.PrintWriter\r\n\r\n// 1. Viajes por zona\r\nval viajesZona = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, COUNT(*) as viajes\r\n  FROM dfFinal GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w1 = new PrintWriter(\"/data/viajes_por_zona.csv\")\r\nw1.println(\"location_id,viajes\")\r\nviajesZona.foreach(r => w1.println(s\"${r(0)},${r(1)}\"))\r\nw1.close()\r\n\r\n// 2. Tarifa media por zona\r\nval tarifaZona = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, ROUND(AVG(fare_amount),2) as tarifa_media\r\n  FROM dfFinal GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w2 = new PrintWriter(\"/data/tarifa_por_zona.csv\")\r\nw2.println(\"location_id,tarifa_media\")\r\ntarifaZona.foreach(r => w2.println(s\"${r(0)},${r(1)}\"))\r\nw2.close()\r\n\r\n// 3. Propina media por zona\r\nval propinaZona = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, ROUND(AVG(tip_amount),2) as propina_media\r\n  FROM dfFinal WHERE tipo_pago = 'Tarjeta' GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w3 = new PrintWriter(\"/data/propina_por_zona.csv\")\r\nw3.println(\"location_id,propina_media\")\r\npropinaZona.foreach(r => w3.println(s\"${r(0)},${r(1)}\"))\r\nw3.close()\r\n\r\n// 4. Distancia media por zona\r\nval distanciaZona = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, ROUND(AVG(trip_distance),2) as distancia_media\r\n  FROM dfFinal GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w4 = new PrintWriter(\"/data/distancia_por_zona.csv\")\r\nw4.println(\"location_id,distancia_media\")\r\ndistanciaZona.foreach(r => w4.println(s\"${r(0)},${r(1)}\"))\r\nw4.close()\r\n\r\n// 5. Duración media por zona\r\nval duracionZona = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, ROUND(AVG(duracion_minutos),2) as duracion_media\r\n  FROM dfFinal GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w5 = new PrintWriter(\"/data/duracion_por_zona.csv\")\r\nw5.println(\"location_id,duracion_media\")\r\nduracionZona.foreach(r => w5.println(s\"${r(0)},${r(1)}\"))\r\nw5.close()\r\n\r\n// 6. Viajes hora pico (8-9h)\r\nval viajesHoraPico = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, COUNT(*) as viajes\r\n  FROM dfFinal WHERE HOUR(tpep_pickup_datetime) BETWEEN 8 AND 9\r\n  GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w6 = new PrintWriter(\"/data/viajes_hora_pico.csv\")\r\nw6.println(\"location_id,viajes\")\r\nviajesHoraPico.foreach(r => w6.println(s\"${r(0)},${r(1)}\"))\r\nw6.close()\r\n\r\n// 7. Viajes hora valle (3-4h)\r\nval viajesHoraValle = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, COUNT(*) as viajes\r\n  FROM dfFinal WHERE HOUR(tpep_pickup_datetime) BETWEEN 3 AND 4\r\n  GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w7 = new PrintWriter(\"/data/viajes_hora_valle.csv\")\r\nw7.println(\"location_id,viajes\")\r\nviajesHoraValle.foreach(r => w7.println(s\"${r(0)},${r(1)}\"))\r\nw7.close()\r\n\r\n// 8. Ingresos totales por zona\r\nval ingresosZona = spark.sql(\"\"\"\r\n  SELECT PULocationID as location_id, ROUND(SUM(total_amount),2) as ingresos_totales\r\n  FROM dfFinal GROUP BY PULocationID\r\n\"\"\").collect()\r\nval w8 = new PrintWriter(\"/data/ingresos_por_zona.csv\")\r\nw8.println(\"location_id,ingresos_totales\")\r\ningresosZona.foreach(r => w8.println(s\"${r(0)},${r(1)}\"))\r\nw8.close()\r\n\r\nprintln(\"Todos los CSVs exportados\")",
