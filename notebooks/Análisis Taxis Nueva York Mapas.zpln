      "text": "%python\r\nimport folium\r\nimport json\r\nimport pandas as pd\r\n\r\nwith open('/data/nyc_taxi_zones.geojson') as f:\r\n    geojson = json.load(f)\r\n\r\ndef hacer_mapa(csv_file, columna, color, titulo):\r\n    df = pd.read_csv(f'/data/{csv_file}')\r\n    df['location_id'] = df['location_id'].astype(int)\r\n    \r\n    m = folium.Map(location=[40.7128, -74.0060], zoom_start=11)\r\n    folium.Choropleth(\r\n        geo_data=geojson,\r\n        data=df,\r\n        columns=[\"location_id\", columna],\r\n        key_on=\"feature.properties.LocationID\",\r\n        fill_color=color,\r\n        fill_opacity=0.7,\r\n        line_opacity=0.2,\r\n        legend_name=titulo\r\n    ).add_to(m)\r\n    return m\r\n\r\nprint(\"Función lista\")",
