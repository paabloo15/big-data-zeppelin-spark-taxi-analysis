    {
      "text": "%spark\n\n// Demanda por franja horaria en laborable vs fin de semana\n\nz.show(\n  spark.sql(\"\"\"\n    SELECT\n      CASE\n        WHEN HOUR(tpep_pickup_datetime) BETWEEN 6 AND 11  THEN '1. Mañana (6-12h)'\n        WHEN HOUR(tpep_pickup_datetime) BETWEEN 12 AND 17 THEN '2. Tarde (12-18h)'\n        WHEN HOUR(tpep_pickup_datetime) BETWEEN 18 AND 22 THEN '3. Noche (18-23h)'\n        ELSE '4. Madrugada (23-6h)'\n      END AS franja,\n      CASE\n        WHEN DAYOFWEEK(tpep_pickup_datetime) IN (1, 7) THEN 'Fin de semana'\n        ELSE 'Laborable'\n      END AS tipo_semana,\n      COUNT(*) AS viajes_totales,\n      COUNT(DISTINCT DATE(tpep_pickup_datetime)) AS num_dias,\n      ROUND(COUNT(*) / COUNT(DISTINCT DATE(tpep_pickup_datetime)), 2) AS viajes_por_dia,\n      ROUND(AVG(total_amount), 2) AS tarifa_media,\n      ROUND(AVG(duracion_minutos), 2) AS duracion_media\n    FROM dfFinal\n    GROUP BY franja, tipo_semana\n    ORDER BY franja, tipo_semana\n  \"\"\")\n)",
      "user": "anonymous",
      "dateUpdated": "2026-04-26T16:04:09+0000",
      "progress": 50,
      "config": {
