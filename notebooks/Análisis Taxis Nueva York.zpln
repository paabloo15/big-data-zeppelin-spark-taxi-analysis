    {
      "text": "%spark\n\n// Eficiencia del viaje por distrito\n\nz.show(\n  spark.sql(\"\"\"\n    SELECT\n      borough_recogida,\n      ROUND(AVG(trip_distance), 2) AS distancia_media_millas,\n      ROUND(AVG(duracion_minutos), 2) AS duracion_media_min,\n      ROUND(AVG(fare_amount), 2) AS tarifa_media,\n      ROUND(AVG(trip_distance) / AVG(duracion_minutos) * 60, 2) AS velocidad_mph,\n      ROUND(AVG(fare_amount) / AVG(trip_distance), 2) AS coste_por_milla\n    FROM dfFinal\n    WHERE borough_recogida IS NOT NULL\n    AND trip_distance > 0\n    AND duracion_minutos > 0\n    GROUP BY borough_recogida\n    ORDER BY velocidad_mph ASC\n  \"\"\")\n)",
      "user": "anonymous",
