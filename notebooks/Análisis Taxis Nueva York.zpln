      "text": "%spark\n\n// Impacto del Año Nuevo en la demanda por hora\n\nz.show(\nspark.sql(\"\"\"\nSELECT\n  HOUR(tpep_pickup_datetime) AS hora,\n  CASE\n    WHEN DAY(tpep_pickup_datetime)=1 THEN '1 Enero'\n    ELSE 'Resto'\n  END AS tipo_dia,\n  ROUND(\n    COUNT(*) / COUNT(DISTINCT DAY(tpep_pickup_datetime)),\n    2\n  ) AS viajes_por_dia\nFROM dfFinal\nGROUP BY hora, tipo_dia\nORDER BY hora\n\"\"\")\n)\n",
