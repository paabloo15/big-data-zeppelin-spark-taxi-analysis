    {
      "text": "%spark\n\n// Viajes al aeropuerto vs viajes normales\n\nz.show(\n  spark.sql(\"\"\"\n    SELECT\n      CASE\n        WHEN tarifa_tipo IN ('JFK', 'Newark') THEN 'Aeropuerto'\n        ELSE 'Estándar'\n      END AS tipo_viaje,\n      COUNT(*) AS viajes,\n      ROUND(AVG(trip_distance), 2) AS distancia_media,\n      ROUND(AVG(duracion_minutos), 2) AS duracion_media,\n      ROUND(AVG(fare_amount), 2) AS tarifa_media,\n      ROUND(AVG(tip_amount), 2) AS propina_media,\n      ROUND(AVG(tip_amount) / AVG(fare_amount) * 100, 2) AS propina_pct,\n      ROUND(AVG(passenger_count), 2) AS pasajeros_medios\n    FROM dfFinal\n    GROUP BY tipo_viaje\n    ORDER BY viajes DESC\n  \"\"\")\n)",
      "user": "anonymous",
