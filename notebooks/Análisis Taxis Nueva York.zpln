    {
      "text": "%spark\r\n\r\n//Pasajeros y su impacto en propina y tarifa\r\n\r\nz.show(\r\n  spark.sql(\"\"\"\r\n    SELECT\r\n      CAST(passenger_count AS INT) AS pasajeros,\r\n      COUNT(*) AS viajes,\r\n      ROUND(AVG(fare_amount), 2) AS tarifa_media,\r\n      ROUND(AVG(tip_amount), 2) AS propina_media,\r\n      ROUND(AVG(trip_distance), 2) AS distancia_media,\r\n      ROUND(AVG(duracion_minutos), 2) AS duracion_media\r\n    FROM dfFinal\r\n    WHERE passenger_count BETWEEN 1 AND 6\r\n    GROUP BY pasajeros\r\n    ORDER BY pasajeros\r\n  \"\"\")\r\n)",
