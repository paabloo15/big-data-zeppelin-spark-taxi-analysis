      "text": "%spark\r\n\r\n// Viajes por hora\r\n\r\nval viajesPorHora = spark.sql(\"\"\"\r\n  SELECT \r\n    HOUR(tpep_pickup_datetime) AS hora, \r\n    COUNT(*) AS viajes,\r\n    ROUND(AVG(fare_amount), 2) AS tarifa_media,\r\n    ROUND(AVG(duracion_minutos), 2) AS duracion_media\r\n  FROM dfFinal\r\n  GROUP BY HOUR(tpep_pickup_datetime)\r\n  ORDER BY hora\r\n\"\"\")\r\n\r\nz.show(viajesPorHora)",
