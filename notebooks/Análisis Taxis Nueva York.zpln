    {
      "text": "%spark\r\n\r\n//  Recogidas vs destinos por distrito (porcentaje)\r\n\r\nz.show(\r\n  spark.sql(\"\"\"\r\n    SELECT\r\n      borough,\r\n      tipo,\r\n      viajes,\r\n      ROUND(viajes * 100.0 / SUM(viajes) OVER (PARTITION BY borough), 2) AS pct_del_distrito\r\n    FROM (\r\n      SELECT borough_recogida AS borough, 'Recogida' AS tipo, COUNT(*) AS viajes\r\n      FROM dfFinal WHERE borough_recogida IS NOT NULL\r\n      GROUP BY borough_recogida\r\n      UNION ALL\r\n      SELECT borough_destino AS borough, 'Destino' AS tipo, COUNT(*) AS viajes\r\n      FROM dfFinal WHERE borough_destino IS NOT NULL\r\n      GROUP BY borough_destino\r\n    )\r\n    ORDER BY borough\r\n  \"\"\")\r\n)",
