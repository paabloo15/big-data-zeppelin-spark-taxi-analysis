    {
      "text": "%spark\r\n\r\n//  Recogidas vs destinos por distrito (diferencia)\r\n\r\nz.show(\r\n  spark.sql(\"\"\"\r\n    SELECT\r\n      borough,\r\n      SUM(CASE WHEN tipo = 'Recogida' THEN viajes ELSE 0 END) AS recogidas,\r\n      SUM(CASE WHEN tipo = 'Destino' THEN viajes ELSE 0 END) AS destinos,\r\n      SUM(CASE WHEN tipo = 'Recogida' THEN viajes ELSE 0 END) -\r\n      SUM(CASE WHEN tipo = 'Destino' THEN viajes ELSE 0 END) AS Diferencia\r\n    FROM (\r\n      SELECT borough_recogida AS borough, 'Recogida' AS tipo, COUNT(*) AS viajes\r\n      FROM dfFinal WHERE borough_recogida IS NOT NULL\r\n      GROUP BY borough_recogida\r\n      UNION ALL\r\n      SELECT borough_destino AS borough, 'Destino' AS tipo, COUNT(*) AS viajes\r\n      FROM dfFinal WHERE borough_destino IS NOT NULL\r\n      GROUP BY borough_destino\r\n    )\r\n    GROUP BY borough\r\n    ORDER BY diferencia DESC\r\n  \"\"\")\r\n)",
      "user": "anonymous",
